#!/bin/sh -e
# start
# part of pidisplay
# call this from rc.local or another startup method

/home/pidisplay/bin/checkusb 2>&1 | tee -a /var/log/pidisplay/checkusb.log
# for debugging, uncomment the output redirect
/home/pidisplay/bin/displayloop   ## >> /var/log/displayloop.log 2>&1 < /dev/null &
# with --loop, clear console is not needed
#/home/pidisplay/bin/clearconsole 5 &

exit 0
